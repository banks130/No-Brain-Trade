{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "python main.py",
    "healthcheckPath": "/api/tokens",
    "healthcheckTimeout": 240,
    "restartPolicyType": "ALWAYS",
    "numReplicas": 1
  }
}
